FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=replace-with-a-long-random-secret-key
JWT_SECRET_KEY=replace-with-another-long-random-secret-key

DATABASE_URL=postgresql://estronix_user:STRONG_DB_PASSWORD@localhost:5432/estronix_db

BREVO_API_KEY=your-brevo-api-key
MAIL_DEFAULT_SENDER=estronix82@gmail.com
MAIL_DEFAULT_SENDER_NAME=Estronix
MAIL_CONSOLE=False
MAIL_SUPPRESS_SEND=False

MPESA_ENV=production
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=your-till-or-paybill
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://YOUR_DOMAIN/payments/mpesa/callback?token=your-callback-secret
MPESA_CALLBACK_TOKEN=your-callback-secret
MPESA_VERIFY_CALLBACK=True

APP_NAME=Estronix
APP_URL=https://YOUR_DOMAIN
ADMIN_EMAIL=estronix82@gmail.com
ADMIN_INITIAL_PASSWORD=replace-with-strong-admin-password
CONTACT_PHONE=0757840780
CONTACT_EMAIL=estronix82@gmail.com
WHATSAPP_NUMBER=0757840780

SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
WTF_CSRF_TIME_LIMIT=3600

RATELIMIT_STORAGE_URI=redis://127.0.0.1:6379/0
MAX_CONTENT_LENGTH_MB=64
MAX_UPLOAD_FILE_SIZE_MB=8
