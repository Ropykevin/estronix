# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-secret-key
JWT_SECRET_KEY=change-this-jwt-secret-key

# Database
DATABASE_URL=postgresql://estronix_user:estronix_pass@localhost:5432/estronix_db

# Email (Brevo REST API — not SMTP)
# Brevo dashboard → SMTP & API → API Keys
BREVO_API_KEY=your-brevo-api-key
MAIL_DEFAULT_SENDER=info@estronix.co.ke
MAIL_DEFAULT_SENDER_NAME=Estronix
# Local dev: print verification/reset links in the terminal (no Brevo needed)
MAIL_CONSOLE=True
MAIL_SUPPRESS_SEND=False

# M-Pesa Daraja API (Safaricom)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://yourdomain.com/payments/mpesa/callback?token=your-callback-secret
MPESA_CALLBACK_TOKEN=your-callback-secret
MPESA_VERIFY_CALLBACK=True

# Application
APP_NAME=Estronix
APP_URL=http://localhost:5000
APP_PORT=5060
PORT=5060
ADMIN_EMAIL=estronix82@gmail.com
ADMIN_INITIAL_PASSWORD=change-this-admin-password
ITEMS_PER_PAGE=12
LOW_STOCK_THRESHOLD=10

# Security
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
WTF_CSRF_TIME_LIMIT=3600

# Rate Limiting (use Redis in production)
RATELIMIT_STORAGE_URI=redis://127.0.0.1:6379/0
